{
  "name": "CyberCalc Neon Interface",
  "version": "1.0.0",
  "colors": {
    "background": "#0a0a0f",
    "panel": "#12121a",
    "surface": "#1a1a2e",
    "cyan": "#00f0ff",
    "magenta": "#ff00aa",
    "yellow": "#ffee00",
    "green": "#00ff88",
    "text": "#e0e0f0",
    "textDim": "#6666aa"
  },
  "typography": {
    "mono": "'Courier New', 'JetBrains Mono', monospace",
    "displayWeight": 700,
    "buttonWeight": 600,
    "letterSpacing": {
      "brand": "6px",
      "panelTitle": "3px",
      "footer": "2px"
    }
  },
  "radii": {
    "panel": "10px",
    "display": "6px",
    "button": "6px",
    "control": "4px"
  },
  "effects": {
    "glowCyan": "0 0 8px #00f0ff, 0 0 20px rgba(0, 240, 255, 0.3)",
    "glowMagenta": "0 0 8px #ff00aa, 0 0 20px rgba(255, 0, 170, 0.3)",
    "scanlineOpacity": 0.15,
    "gridSize": "42px"
  },
  "motion": {
    "press": "100ms ease",
    "glitchBurst": "180ms steps(2, end)",
    "tracePulse": "3.2s ease-in-out infinite",
    "hologramRise": "420ms ease-out"
  }
}
